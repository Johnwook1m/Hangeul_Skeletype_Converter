# Google API 연동 설정
# 아래 값들을 채운 뒤 파일 이름을 .env로 변경하세요.

# 서비스 계정 JSON 키 파일 경로 (절대 경로 권장)
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json

# Google Drive 루트 폴더 ID
# Drive에서 폴더 열었을 때 URL의 마지막 부분: https://drive.google.com/drive/folders/<FOLDER_ID>
GOOGLE_DRIVE_ROOT_FOLDER_ID=your_folder_id_here

# Google Sheets 스프레드시트 ID
# Sheets URL: https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# (선택) 시트 이름 - 기본값: Archives
# GOOGLE_SHEET_NAME=Archives
